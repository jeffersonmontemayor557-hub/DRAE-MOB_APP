EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Set to false to hide "Create account" on the start screen (staff-provisioned accounts only).
# Eligibility is still enforced server-side: only emails already on file in profiles can sign up.
EXPO_PUBLIC_ALLOW_SELF_SIGNUP=true

# Weather tab — free API key from https://openweathermap.org/api (Current Weather + 5 Day / 3 Hour Forecast)
EXPO_PUBLIC_OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
# Optional: defaults to Dasmariñas area if omitted
EXPO_PUBLIC_WEATHER_LAT=14.3294
EXPO_PUBLIC_WEATHER_LON=120.9367
